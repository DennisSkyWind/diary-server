# 环境配置 - 复制为 .env 后修改

# 服务端口
PORT=3333

# 日记文件目录（Markdown日记存放位置）
DIARY_DIR=./data/diary

# 数据目录（股票、健康、日程等数据文件）
COPAW_DIR=./data

# AI服务API Key（支持OpenAI/DashScope/DeepSeek等）
AI_API_KEY=

# AI服务提供商（openai/dashscope/deepseek/custom）
AI_PROVIDER=openai

# Python路径（微博发布功能需要）
PYTHON_PATH=python3

# 百度网盘CLI路径（可选，用于备份）
BDPAN_PATH=bdpan